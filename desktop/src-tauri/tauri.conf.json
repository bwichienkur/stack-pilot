{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StackPilot",
  "version": "0.1.0",
  "identifier": "io.stackpilot.desktop",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "StackPilot",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:5000 https://api.stackpilot.io; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
